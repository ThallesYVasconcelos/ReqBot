# ===========================================
# REQUIREMENTS ASSISTANT API - Variáveis de Ambiente
# ===========================================
# Copie para .env e preencha os valores.
# O .env não é versionado (gitignore).
# ===========================================

# --- Banco de Dados ---
# Usado em spring.datasource e pgvector (padrão: postgres/postgres)
# SPRING_DATASOURCE_PASSWORD=sua_senha
# PGVECTOR_PASSWORD=sua_senha

# --- JWT (obrigatório) ---
# Segredo para assinar/validar tokens (mín. 32 caracteres)
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET_32_CHARS_MINIMUM

# --- IA - Gemini (se ai.provider=gemini) ---
GEMINI_API_KEY=

# --- IA - OpenAI (se ai.provider=openai) ---
OPENAI_API_KEY=

# --- Google OAuth (opcional) ---
# Client ID para validar audience (aud) do idToken
GOOGLE_CLIENT_ID=

# --- Admin emails ---
# Configurar em application.properties: auth.admin.emails=admin@exemplo.com
# Ou via variável se usar suporte a ${ADMIN_EMAILS} no properties
